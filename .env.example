# ============================================
# FORGE FITNESS — Backend Environment Variables
# Copy to .env and fill in all values
# NEVER commit .env to git
# ============================================

# ----- Server -----
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ----- MongoDB Atlas -----
# 1. Go to https://cloud.mongodb.com
# 2. Create free M0 cluster
# 3. Create DB user: forge_user / <strong password>
# 4. Whitelist IP: 0.0.0.0/0 (all) for Railway, or specific IPs
# 5. Copy connection string below
MONGODB_URI=mongodb+srv://forge_user:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/forge_fitness?retryWrites=true&w=majority

# ----- JWT -----
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-char-hex-secret-here
JWT_REFRESH_SECRET=another-64-char-hex-secret-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ----- Google OAuth -----
# 1. Go to https://console.cloud.google.com
# 2. Create project > APIs & Services > Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ----- Razorpay -----
# 1. Sign up at https://razorpay.com
# 2. Dashboard > Settings > API Keys > Generate Test Key
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ----- Cloudinary -----
# 1. Sign up at https://cloudinary.com (free tier: 25GB storage)
# 2. Dashboard > Settings > Upload > Add upload preset (unsigned)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ----- Resend (Email) -----
# 1. Sign up at https://resend.com (free: 3000 emails/month)
# 2. Add & verify your domain, or use @resend.dev for testing
# 3. API Keys > Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=FORGE Fitness <noreply@forgefitness.com>
EMAIL_REPLY_TO=support@forgefitness.com

# ----- Redis (optional, for rate limiting + caching) -----
# Free tier at https://upstash.com
REDIS_URL=redis://default:password@xxxx.upstash.io:6379

# ----- Admin -----
# First admin account seeded by npm run seed
ADMIN_EMAIL=admin@forgefitness.com
ADMIN_PASSWORD=ChangeThisStrongPassword123!
ADMIN_NAME=Forge Admin
